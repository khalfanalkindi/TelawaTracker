# Required — used to sign login sessions (use a long random string)
AUTH_SECRET=change-me-to-a-long-random-string

# Optional — timezone for streak day boundaries (set on Railway too)
# TZ=Asia/Muscat

# Optional — where db.json is stored (mount a Railway volume here for persistence)
# DATA_DIR=/data

# SMTP — required in production to send OTP emails
# Without these, OTP is printed to server logs (dev only)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Telawa Tracker <your@email.com>"
